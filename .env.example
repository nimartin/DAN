# JSONBin.io — partage de l'historique entre appareils
# 1) Va sur https://jsonbin.io et crée un compte
# 2) Crée un nouveau bin avec le contenu : {"expenses":[],"refusedAttempts":0}
# 3) Récupère l'ID du bin (dans l'URL) et ta Master Key (Account → API Keys)
# 4) Copie ce fichier en .env et remplis les valeurs

VITE_JSONBIN_BIN_ID=
VITE_JSONBIN_KEY=
